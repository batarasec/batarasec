# BataraSec Community environment
# Copy to .env before running docker compose directly.

BATARASEC_VERSION=0.1.0-community
COMPOSE_PROJECT_NAME=batarasec-community
HTTP_PORT=8088
HTTPS_PORT=8444
BATARASEC_API_TAG=api-community-0.1.0
BATARASEC_WEB_TAG=web-community-0.1.0
BATARASEC_WORKER_TAG=worker-community-0.1.0
BATARASEC_EDITION=community
NEXT_PUBLIC_BATARASEC_EDITION=community

# Public URL used by the web app and agent installer commands.
APP_URL=http://localhost:8088
PUBLIC_API_URL=http://localhost:8088/api

# Database and Redis defaults for the bundled docker-compose.yml.
POSTGRES_DB=batarasec
POSTGRES_USER=batarasec
POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgresql://batarasec:change-me-postgres-password@postgres:5432/batarasec
REDIS_URL=redis://redis:6379

# Required secrets. install.sh should generate strong values automatically.
JWT_SECRET=change-me-generate-random
LICENSE_SECRET=change-me-generate-random
SETTINGS_ENCRYPTION_KEY=change-me-generate-random-32-bytes

# Initial superadmin. install.sh should generate a password unless explicitly set.
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_EMAIL=superadmin@batarasec.local
SUPERADMIN_PASSWORD=

# Community feature defaults.
SHOW_TODO_PAGE=false
NEXT_PUBLIC_SHOW_TODO_PAGE=false
ENABLE_SIGNUP=false

# Local vulnerability database sync.
OSV_DEV_SYNC=true
OSV_DEV_SYNC_HOUR=0
OSV_DEV_SYNC_MINUTE=0
OSV_DEV_SYNC_TIMEZONE=Asia/Jakarta

# Optional AI BYOK configuration. Leave blank to disable AI features.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=

# Agent binaries served by the API container.
AGENT_BINARIES_DIR=/var/lib/batarasec/agent-binaries

# Community limits. These may be enforced by Community images.
COMMUNITY_MAX_ORGANIZATIONS=1
COMMUNITY_MAX_WORKSPACES=1
COMMUNITY_MAX_PROJECTS=3
COMMUNITY_MAX_USERS=5
COMMUNITY_MAX_AGENTS=5
COMMUNITY_MAX_OPEN_FINDINGS=10000
COMMUNITY_MAX_BACKUP_ARCHIVES=3
COMMUNITY_MAX_REPORT_ARCHIVES=5
